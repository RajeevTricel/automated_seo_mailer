{
  "name": "automatedseomailerstaging",
  "main": "src/index.js",
  "compatibility_date": "2026-04-07",
  "vars": {
    "GITHUB_OWNER": "RajeevTricel",
    "GITHUB_REPO": "automated_seo_mailer",
    "GITHUB_WORKFLOW_ID": "shadow_site_intelligence.yml",
    "GITHUB_REF": "main",
    "ALLOWED_ORIGIN": "http://localhost:3000"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tricel-shadow-staging",
      "database_id": "PUT_YOUR_REAL_D1_DATABASE_ID_HERE"
    }
  ]
}
